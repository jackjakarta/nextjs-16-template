{
  "enabledPlugins": {
    "context7@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",

      "Bash(pnpm format:*)",
      "Bash(pnpm format:check:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm types:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm checks:*)",
      "Bash(pnpm db:generate:*)",

      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "deny": ["Bash(pnpm build:*)", "Bash(pnpm db:migrate:*)"]
  }
}
