    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.1",
    "lucide-react": "1.0.1",
    "next": "16.2.1",
    "next-intl": "4.8.3",
    "next-themes": "0.4.6",
    "pg": "8.20.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
