    "better-auth": "1.6.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.23",
    "lucide-react": "1.14.0",
    "next": "16.2.7",
    "next-intl": "4.11.1",
    "next-themes": "0.4.6",
    "pg": "8.20.0",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.75.0",
    "tailwind-merge": "3.6.0",
