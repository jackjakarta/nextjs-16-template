    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.6",
    "jsdom": "29.1.1",
    "shadcn": "4.8.0",
    "tailwindcss": "4.3.0",
