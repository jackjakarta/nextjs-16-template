    "db:studio": "drizzle-kit studio --config=./src/db/drizzle.config.ts",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "pipeline": "$(git rev-parse --show-toplevel)/scripts/pipeline.sh",
    "start": "next start",
    "test": "vitest --run",
    "types": "tsc --noEmit"
  },
  "dependencies": {
