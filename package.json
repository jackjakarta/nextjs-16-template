{
  "name": "nextjs-16-template",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "next build",
    "checks": "$(git rev-parse --show-toplevel)/scripts/checks.sh",
    "db:generate": "drizzle-kit generate --config=./src/db/drizzle.config.ts",
