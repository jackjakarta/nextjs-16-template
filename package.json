    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.1",
    "jsdom": "29.0.1",
    "shadcn": "4.1.0",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
